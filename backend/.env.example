# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# --- DATABASE (Supabase) ---
# Get this from: Supabase Dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# --- JWT ---
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_string
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_LONG_EXPIRES_IN=30d

# --- GOOGLE OAUTH (optional) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://dairy-production-5177.up.railway.app/api/auth/google/callback

# --- SMTP (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Dairy ERP <noreply@dairy.local>

# --- APP ---
PORT=5000
NODE_ENV=production
CLIENT_URL=https://dairy-sand.vercel.app
ALLOWED_ORIGINS=https://dairy-sand.vercel.app
